  set.seed(1)
  d <- data.frame(y = rnorm(40), x = rnorm(40),
                  g = factor(rep(1:5, 8)))
  fit_g <- fb(y ~ x + (1 | g), data = d, backend = "greta",
              n_samples = 100, warmup = 100, chains = 1,
              verbose = FALSE)
