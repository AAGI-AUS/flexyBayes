    fit_g, fit_i,
    transform_b = list(
      "Precision for g"                         = prec_to_sd,
      "Precision for the Gaussian observations" = prec_to_sd
    ),
    name_map = c(
      "(Intercept):1"                           = "mu_atg",
      "x:1"                                     = "beta_x",
      "Precision for g"                         = "sigma_g",
      "Precision for the Gaussian observations" = "sigma_e_atg"
    )
  )
  print(tri)
