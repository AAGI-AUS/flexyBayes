# Host-local INLA-mapping verification artefacts -- per-host (carry INLA
# version, timestamp, agreement snapshot); must not enter shared history.
# Regenerated locally by the INLA-verification tests; absence on a fresh
# checkout is the intended fail-safe.
inst/extdata/inla-verification/

# Decision-knowledge archive -- local dev artefact, not part of the package.
ledger/

# pkgdown output (rebuilt by CI; not committed)
docs/

# Stress-harness outputs (generated; the harness scripts ship, the results
# directory is local-only).
tools/stress_results/

# testthat transient failed-test records
tests/testthat/_problems/
